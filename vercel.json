{
    "buildCommand": "next build",
    "outputDirectory": ".next",
    "devCommand": "next dev",
    "env": {
        "TMDB_API_KEY": "@tmdb_api_key"
    },
    "functions": {
        "api/**/*.js": {
            "maxDuration": 30,
            "memory": 1024
        }
    },
    "headers": [
        {
            "source": "/api/:path*",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "no-cache, no-store, must-revalidate"
                }
            ]
        },
        {
            "source": "/_next/static/:path*",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=31536000, immutable"
                }
            ]
        }
    ]
}